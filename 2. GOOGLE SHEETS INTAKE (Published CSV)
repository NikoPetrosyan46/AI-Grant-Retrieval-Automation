def fetch_google_sheets_intake(sheet_csv_url):
    """
    Fetches real-time survey data from a 'Published to Web' Google Sheet CSV link.
    """
    print("Fetching survey intake data from Google Sheets...")
    try:
        # Pandas reads the live CSV URL directly
        df = pd.read_csv(sheet_csv_url)
        
        documents = []
        for _, row in df.iterrows():
            # Adjust column names to match your actual Google Sheet headers
            content = (
                f"Applicant: {row.get('Applicant_Name', 'Unknown')}\n"
                f"Needs: {row.get('Needs_Requested', 'Not specified')}"
            )
            doc = Document(
                page_content=content,
                metadata={
                    "source": "Google Sheets Intake", 
                    "date": str(row.get('Timestamp', 'N/A'))
                }
            )
            documents.append(doc)
        print(f"Successfully ingested {len(documents)} survey responses.")
        return documents
    except Exception as e:
        print(f"Error fetching Google Sheets data: {e}")
        return []
