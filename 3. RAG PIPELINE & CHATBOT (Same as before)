def initialize_rag_pipeline(documents):
    if not documents:
        print("Warning: No documents found to index.")
        return None
    
    print("Embedding documents into ChromaDB...")
    embeddings = OllamaEmbeddings(model="nomic-embed-text") 
    vectorstore = Chroma.from_documents(
        documents=documents, 
        embedding=embeddings,
        persist_directory="./grant_chroma_db"
    )
    return vectorstore.as_retriever(search_kwargs={"k": 3})

def create_chatbot(retriever):
    llm = Ollama(model="llama3")
    system_prompt = (
        "You are an internal Grant Database Assistant. Use the context to answer questions. "
        "Context: {context}"
    )
    prompt = ChatPromptTemplate.from_messages([
        ("system", system_prompt),
        ("human", "{input}"),
    ])
    
    combine_docs_chain = create_stuff_documents_chain(llm, prompt)
    return create_retrieval_chain(retriever, combine_docs_chain)
